# Environment variables for the local_mock profile.
# Copy to .env.local and fill in values (no real secrets needed for local profile).
# .env.local is gitignored.

# ── Local profile (no secrets needed) ────────────────────────────────────────
ADAS_DATA_ROOT=./data/synthetic
ADAS_STATE_DIR=./state
ADAS_CHECKPOINT_DIR=./checkpoints
ADAS_MODEL_PATH=./checkpoints/fusion.pt
ADAS_SERVE_PORT=8080

# ── Cloud profile (Azure — required for +profile=cloud_prod) ─────────────────
# AZURE_STORAGE_ACCOUNT=<your_storage_account>
# AZURE_STORAGE_CONN_STR=<DefaultEndpointsProtocol=https;AccountName=...>
# AZURE_BLOB_CONTAINER=adas-data
# AZURE_SUBSCRIPTION_ID=<your_subscription_id>
# AZURE_RESOURCE_GROUP=<your_resource_group>
# AZURE_ML_WORKSPACE=<your_aml_workspace>
# RAY_CLUSTER_ADDRESS=ray://<head-node>:10001
